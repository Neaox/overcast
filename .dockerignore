# Ignore everything, then allowlist only what the build needs.
*

# ---- Docs index generation (stage 1) ---------------------------------------
!scripts/
!scripts/docs-index.go

# ---- Go builder (stage 3) ---------------------------------------------------
!go.mod
!go.sum
!embed.go
!embed_slim.go
!cmd/
!internal/
!docs/
!docs/*.md
!docs/cdk/
!docs/cdk/**
!docs/compatibility/
!docs/compatibility/**
!docs/perf-baselines/
!docs/perf-baselines/**
!docs/services/
!docs/services/**

# ---- Web builder (stage 2) --------------------------------------------------
!web/
# npm ci runs inside the container — host node_modules are dead weight (~800 MB).
web/node_modules/
web/api/node_modules/
# Build outputs that may exist locally.
web/dist/
web/dist-server/

# ---- Console stage (stage 4) ------------------------------------------------
!docker/
