coverage.out
coverage.html

# compiled binaries
bin/
# stray root-level binaries from `go build ./cmd/...` without -o
/overcast
/overcastd
# any stray root-level .exe (ad-hoc Windows cross-compile tests, etc.)
/*.exe

# go test binaries (from `go test -c`) and profiler outputs
*.test
*.prof
*.pprof
*.trace

# air hot-reload output
tmp/

# persistent state (dev container data dir — survives rebuilds, not for VCS)
.overcast/

# compat dashboard — last run results (persisted across server restarts, not for VCS)
compat-results.json
# compat agent-friendly text report (regenerated after every run, not for VCS)
compat-report.txt

# log files
*.log
logs.txt

# node_modules (root-level catch-all for any suites without their own .gitignore)
**/node_modules/

# mkcert TLS certificates (generated by vite-plugin-mkcert for HTTPS dev server)
.cert/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

.cache
.npm
