coverage.out
coverage.html

# compiled binaries
bin/
# stray root-level binaries from `go build ./cmd/...` without -o
/overcast
/overcastd
# any stray root-level .exe (ad-hoc Windows cross-compile tests, etc.)
/*.exe

# go test binaries (from `go test -c`) and profiler outputs
*.test
*.prof
*.pprof
*.trace

# air hot-reload output
tmp/

# persistent state (dev container data dir — survives rebuilds, not for VCS)
.overcast/
.devcontainer/.env
.devcontainer/docker-compose.yaml

# compat dashboard — last run results (persisted across server restarts, not for VCS)
compat-results.json
# compat agent-friendly text report (regenerated after every run, not for VCS)
compat-report.txt

# docs nav/search index — regenerated from docs/ by scripts/docs-index.go
# (run `make docs-index` / `task docs-index`, or `go generate ./internal/docssearch`).
# Never checked in so a stale copy can't linger in git; go build/test, vite
# dev, and the Docker build all regenerate it themselves. See Dockerfile.
/web/src/docs-index.gen.ts
/internal/docssearch/index.gen.go

# log files
*.log
logs.txt

# node_modules (root-level catch-all for any suites without their own .gitignore)
**/node_modules/

# mkcert TLS certificates (generated by vite-plugin-mkcert for HTTPS dev server)
.cert/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

.cache
.npm
